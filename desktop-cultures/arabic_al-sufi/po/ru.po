msgstr ""
"Самая южная из [двух] звезд между передними ногами Медведицы [Большой] и "
"головой Льва."

msgid "The one north of it"
msgstr "Та, что севернее неё"

msgid "The rearmost of the remaining three faint stars"
msgstr "Самая дальняя  из оставшихся трёх тусклых звёзд"

msgid "The one in advance of this"
msgstr "Та, что опередила эту"

msgid "The one in advance again of the latter"
msgstr "Та, что выше последней"

msgid "The star between the front legs [of Ursa Major] and Gemini"
msgstr "Звезда между передними лапами [Большой Медведицы] и Близнецами"

msgid "The dark camel"
msgstr "Тёмный верблюд"

msgid "The Oryx"
msgstr "Орикс"

msgid "The little goat"
msgstr "Козочка"

msgid "The leader"
msgstr "Лидер"

msgid "Liver of the lion"
msgstr "Печень льва"

