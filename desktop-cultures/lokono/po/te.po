# Sky culture name
msgid "Lokono"
msgstr ""

msgid "Spirit of the black curassow"
msgstr "నల్ల కురసో ఆత్మ"

msgid "Grill"
msgstr "ఇనప తడిక"

msgid "Scores of stars"
msgstr "బోలెడు నక్షత్రాలు"

msgid "Man without a thigh"
msgstr "తొడ లేని మనిషి"

msgid "Jaw of the tapir"
msgstr "టాపిర్ దవడ"

msgid "Spirit of the awara palm"
msgstr "అవారా పామ్ ఆత్మ"

msgid "Spirit of the blue crab"
msgstr "నీలి పీత ఆత్మ"

msgid "Spirit of the cocoi heron"
msgstr "కొకోయి హెరాన్ ఆత్మ"

msgid "Spirit of the four-eyed fish"
msgstr "నాలుగు కళ్ళ చేప ఆత్మ"

msgid "Spirit of green sea turtle"
msgstr "ఆకుపచ్చ సముద్రపు తాబేలు ఆత్మ"

msgid "Spirit of the Muscovy duck"
msgstr "మాస్కో బాతు ఆత్మ"

msgid "Alêti"
msgstr "అలేటి"

msgid "Yokhârhin"
msgstr "యోఖార్‌హిన్"

msgid "Mali"
msgstr "మాలి"

msgid "Hadali"
msgstr "హడాలి"

msgid "Kathi"
msgstr "కాథి"

msgid "Warokuma"
msgstr "వరోకుమా"

msgid "Wiwa kalemero"
msgstr "వివా కాలెమెరో"
