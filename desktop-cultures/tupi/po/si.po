# Sky culture name
msgid "Tupi-Guarani"
msgstr ""

msgid "Old Man"
msgstr "මහල්ලා"

msgid "White Ostrich"
msgstr "සුදු පැස්බරා"

msgid "Anta do Norte (Tapi'i)"
msgstr "ඇන්‍ටා ඩො නොර්ටේ (ටපි)"

msgid "Veado"
msgstr "වේඩෝ (ගෝනා)"

msgid "Joykexo"
msgstr "ජොයිකෙක්සො"

msgid "Vespeiro (Eixu)"
msgstr "සන්ධ්‍යා දේව මෙහෙය සම්බන්ධ"

msgid "Queixada da Anta (Tapi'i rainhyka)"
msgstr "කුවෙක්සඩා ඩ ඇන්ටා"

msgid "Quira-Rupia"
msgstr "කුයිරා-රුපියා"
