# Sky culture name
msgid "Aztec"
msgstr "आज्स्टेकीय"

msgid "Mamalhuaztli (The New fire)"
msgstr "ममाल्हुआझ्तली (नईं अग्नि)"

msgid "Tianquiztli  (The Market)"
msgstr "तिआन्कुइझ्त्लि (बाजार)"

msgid "Citlaltlachtli (The ball game of the stars)"
msgstr "चित्लाल्त्लाचतली (तारों का खेल)"

msgid "Xonecuilli (Twisted foot)"
msgstr "ज़ोनेकुइली (टेढ़ें पैर)"

msgid "Colotl Ixayac (Scorpion face)"
msgstr "कोलोत्ल (बिच्छू चेहरा)"
