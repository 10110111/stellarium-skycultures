# Sky culture name
msgid "Aztec"
msgstr ""

msgid "Mamalhuaztli (The New fire)"
msgstr "మామల్‌హూజట్లీ (ది న్యూ ఫైర్)"

msgid "Tianquiztli  (The Market)"
msgstr "టియాన్‌క్విజిట్లీ (ది మార్కెట్)"

msgid "Citlaltlachtli (The ball game of the stars)"
msgstr "సిట్లాల్‌ట్లాచిట్లీ (ది బాల్ గేమ్ ఆఫ్ ది స్టార్స్)"

msgid "Xonecuilli (Twisted foot)"
msgstr "క్సోనెకిల్లీ (ట్విస్టెడ్ ఫూట్)"

msgid "Colotl Ixayac (Scorpion face)"
msgstr "కొలొట్ల్ ఇక్సాయాక్ (స్కార్పియన్ ఫాకె)"
