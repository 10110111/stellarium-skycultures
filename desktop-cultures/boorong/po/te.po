msgstr "జూయిట్"

msgid "Neilloan"
msgstr "నీల్లోన్"

msgid "Totyarguil"
msgstr "టోట్యార్గిల్"

msgid "Karik Karik"
msgstr "కారిక్ కారిక్"

msgid "Berm-berm-gle"
msgstr "బెర్మ్-బెర్మ్-గ్లె"

msgid "Bunya"
msgstr "బున్యా"

msgid "Tourchingboiongerra"
msgstr "టోర్చిన్‌బోయిన్‌జెర్రా"

msgid "Kourt-chin"
msgstr "కోర్ట్-చిన్"

msgid "Warring"
msgstr "వారింగ్"

msgid "Kulkanbulla"
msgstr "కుల్కన్‌బుల్లా"

msgid "Lamankurrk"
msgstr "లామాంకుర్ర్క్"

msgid "Gellarlec"
msgstr "గెల్లార్లెక్"

msgid "Warepil"
msgstr "వారెపిల్"

msgid "Colowgulloric Warepil"
msgstr "కొలౌగుల్లొరిక్ వారెపిల్"

msgid "Won"
msgstr "వన్"

msgid "Weetkurrk"
msgstr "వీట్కుర్ర్క్"

msgid "War"
msgstr "వార్"

msgid "Collowgulloric War"
msgstr "కొల్లౌగుల్లొరిక్ వార్"

msgid "Yerredetkurrk"
msgstr "యెర్రెడెట్కుర్ర్క్"

msgid "Otchocut"
msgstr "ఒట్చొకుట్"

msgid "Collenbitchick"
msgstr "కాల్లెన్‌బిట్చిక్"

msgid "Yurree"
msgstr "యుర్రీ"

msgid "Wanjel"
msgstr "వాంజెల్"

msgid "Purra"
msgstr "పుర్రా"

msgid "Unurgunite"
msgstr "యునుర్గునైట్"

#. TRANSLATORS: Native name of the Sun in Boorong culture
msgid "Day"
msgstr "రోజు"

#. TRANSLATORS: Native name of the Moon in Boorong culture
msgid "Mityan"
msgstr "మిట్యన్"

#. TRANSLATORS: Native name of Venus in Boorong culture
msgid "Elder sister"
msgstr ""

#. TRANSLATORS: Native name of Jupiter in Boorong culture
msgid "Sulphur-crested white cockatoo"
msgstr ""
