# Sky culture name
msgid "Boorong"
msgstr ""

msgid "Long-necked tortoise"
msgstr "పొడవాటి మెడ గల తాబేలు"

msgid "Fan-tailed cockatoo"
msgstr "విసనకర్ర తోక చిలుక"

msgid "Two teenage boys"
msgstr "ఇద్దరు కుర్రాళ్ళు"

msgid "Girls"
msgstr "అమ్మాయిలు"

msgid "Red kangaroo"
msgstr "ఎర్ర కంగారూ"

msgid "Ring-tail possum"
msgstr "రింగుల తోక అడవిపిల్లి"

msgid "Red-rumped parrot"
msgstr "ఎర్ర వీపు చిలుక"

msgid "Crow"
msgstr "కాకి"

msgid "Female crow, wife of War"
msgstr "ఆడ కాకి, గయ్యాళి పెళ్ళాం"

msgid "Owlet nightjar"
msgstr "గుడ్లగూబ పిట్ట"

msgid "Needlewood hakea and willie wagtails"
msgstr "నీడిల్‌వుడ్ హాక్ అండ్ విల్లీ వాగ్టెయిల్స్"

msgid "Red-kneed dotterel"
msgstr "ఎర్ర మోకాలి ఉల్లంగిపిట్ట"

msgid "Australian kestrel"
msgstr "ఆస్ట్రేలియా డేగ"

msgid "Mallee fowl"
msgstr "మాలీ నెమలి"

msgid "Jacky lizard"
msgstr "జాకీ బల్లి"

msgid "Male and female brolga"
msgstr "మగ, ఆడ బ్రోల్గా"

msgid "Great fish"
msgstr "గొప్ప చేప"

msgid "Wedge tailed eagle"
msgstr "వెడ్జి తోక గద్ద"

msgid "Female eagle, wife of Warepil"
msgstr "ఆడ గద్ద, వారేపిల్ భార్య"

msgid "Emu"
msgstr "ఈము"

msgid "Purple crowned lorikeet"
msgstr "ఊదా జుట్టు లోరికీట్"

msgid "Meat ant"
msgstr "మాంసపు చీమ"

msgid "Galaxy"
msgstr "నక్షత్ర సమూహం"

msgid "Singing bushlark"
msgstr "పాడే బుష్‌లార్క్"

msgid "Pink cockatoo"
msgstr "గులాబీ చిలుక"

msgid "Species of ant"
msgstr "చీమ జాతులు"

msgid "Boomerang"
msgstr "బూమరాంగ్"

msgid "The maned snake"
msgstr "జూలు గల పాము"

msgid "Marpeankurrk"
msgstr "మార్పీన్‌కుర్ర్క్"

