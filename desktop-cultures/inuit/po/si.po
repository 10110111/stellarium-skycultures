# Sky culture name
msgid "Inuit"
msgstr ""

msgid "Two Sunbeams"
msgstr "හිරු කදම්බ යුගල"

msgid "Two Placed Far Apart"
msgstr "දුරින් තබන ලද්දෝ"

msgid "Dogs"
msgstr "සුනඛයින්"

msgid "Collarbones"
msgstr "අකු ඇට"

msgid "Lamp Stand"
msgstr "ලාම්පුව"

msgid "Caribou"
msgstr "පිණිමුවා"

msgid "Two in Front"
msgstr "ඉදිරියෙන් සිටින දෙදෙනා"

msgid "Breastbone"
msgstr "පපුඇටය"

msgid "Runners"
msgstr "දිගන"

msgid "Blubber Container"
msgstr "තෙල් භාජනය"

msgid "The One Behind"
msgstr "පිටුපස සිටින කෙනා"

msgid "The Old Woman"
msgstr "මැහැලිය"

msgid "Spirit of a Polar Bear"
msgstr "හිම වළසා"

msgid "Never Moves"
msgstr "නොසෙලවෙන්නෝ"

msgid "Name of a Murdered Man"
msgstr "මැරුණු මිනිසා"

msgid "Flickering"
msgstr "ලෙලෙන දිලෙන"

msgid "Nephews"
msgstr "මුනුබුරන්"

msgid "The Old Man"
msgstr "මහල්ලා"

msgid "The Little Orphan Boy"
msgstr "පුංචි අනාථ දරුවා"
