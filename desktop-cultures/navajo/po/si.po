# Sky culture name
msgid "Navajo"
msgstr ""

msgid "Revolving Male"
msgstr "කැරකෙන මිනිහා"

msgid "Revolving Female"
msgstr "කැරකෙන ගැහැනිය"

msgid "Man with Feet Apart"
msgstr "පාද ඇත් වූ මිනිසා"

msgid "Lizard"
msgstr "උරගයා"

msgid "Dilyehe"
msgstr "ඩිල්යෙහෙ"

msgid "First Big One"
msgstr "පළවෙනි විශාලතමයා"

msgid "Rabbit Tracks"
msgstr "හාවාගේ අඩි සළකුණු"

msgid "First Slim One"
msgstr "ප්‍රථම කෙට්ටු පුද්ගලයා"
