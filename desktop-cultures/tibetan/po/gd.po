# Sky culture name
msgid "Tibetan"
msgstr ""

# Tibetan constellation, native: Luk
msgid "Aries"
msgstr "An Reithe (Aries)"

# Tibetan constellation, native: Lang
msgid "Taurus"
msgstr "An Tarbh (Taurus)"

# Tibetan constellation, native: Trik
msgid "Gemini"
msgstr "An Dà Leth-aon no Gaolag is Gràdhag na Caiginn (Gemini)"

# Tibetan constellation, native: Karkata
msgid "Cancer"
msgstr "Am Partan (Cancer)"

# Tibetan constellation, native: Senge
msgid "Leo"
msgstr "An Leòmhann (Leo)"

# Tibetan constellation, native: Pumo
msgid "Virgo"
msgstr "An Òigh (Virgo)"

# Tibetan constellation, native: Sangwa
msgid "Libra"
msgstr "A’ Mheidh (Libra)"

# Tibetan constellation, native: Dikpa
msgid "Scorpius"
msgstr "An Sgairp (Scorpius)"

# Tibetan constellation, native: Zhu
msgid "Sagittarius"
msgstr "An Saighdear (Sagittarius)"

# Tibetan constellation, native: Chusin
msgid "Capricornus"
msgstr "An Gobhar (Capricornus)"

# Tibetan constellation, native: Bumpa
msgid "Aquarius"
msgstr "An Giùlanair Uisge (Aquarius)"

# Tibetan constellation, native: Nya
msgid "Pisces"
msgstr "Na h-Èisg (Pisces)"
