# Sky culture name
msgid "Tibetan"
msgstr ""

# Tibetan constellation, native: Luk
msgid "Aries"
msgstr "ඒරියස් (මේෂ)"

# Tibetan constellation, native: Lang
msgid "Taurus"
msgstr "ටෝරස් (වෘෂභ)"

# Tibetan constellation, native: Trik
msgid "Gemini"
msgstr "ජෙමිනි (මිථුන)"

# Tibetan constellation, native: Karkata
msgid "Cancer"
msgstr "කැන්සර් (කටක)"

# Tibetan constellation, native: Senge
msgid "Leo"
msgstr "ලියෝ (සිංහ)"

# Tibetan constellation, native: Pumo
msgid "Virgo"
msgstr "වර්ගෝ (කන්‍යා)"

# Tibetan constellation, native: Sangwa
msgid "Libra"
msgstr "ලිබ්රා (තුලා)"

# Tibetan constellation, native: Dikpa
msgid "Scorpius"
msgstr "ස්කෝර්පියස් (වෘශ්චික)"

# Tibetan constellation, native: Zhu
msgid "Sagittarius"
msgstr "සැජිටේරියස් (ධනු)"

# Tibetan constellation, native: Chusin
msgid "Capricornus"
msgstr "කැප්රිකෝනස් (මකර)"

# Tibetan constellation, native: Bumpa
msgid "Aquarius"
msgstr "ඇක්වේරියස් (කුම්භ)"

# Tibetan constellation, native: Nya
msgid "Pisces"
msgstr "පීසස් (මීන)"
