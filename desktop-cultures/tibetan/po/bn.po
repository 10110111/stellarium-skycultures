# Sky culture name
msgid "Tibetan"
msgstr ""

# Tibetan constellation, native: Luk
msgid "Aries"
msgstr "ভেড়া (মেষ)"

# Tibetan constellation, native: Lang
msgid "Taurus"
msgstr "ষাঁড় (বৃষ)"

# Tibetan constellation, native: Trik
msgid "Gemini"
msgstr "যময (মিথুন)"

# Tibetan constellation, native: Karkata
msgid "Cancer"
msgstr "কাঁকড়া (কর্কট)"

# Tibetan constellation, native: Senge
msgid "Leo"
msgstr "সিংহ"

# Tibetan constellation, native: Pumo
msgid "Virgo"
msgstr "কুমারী (কন্যা)"

# Tibetan constellation, native: Sangwa
msgid "Libra"
msgstr "দাঁড়িপাল্লা (তুলা)"

# Tibetan constellation, native: Dikpa
msgid "Scorpius"
msgstr "কাঁকড়া বিছে (বৃশ্চিক)"

# Tibetan constellation, native: Zhu
msgid "Sagittarius"
msgstr "তীরন্দাজ (ধনু)"

# Tibetan constellation, native: Chusin
