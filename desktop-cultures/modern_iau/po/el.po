#. TRANSLATORS: https://iau.org/news/pressreleases/detail/iau1912/
msgid "Nenque"
msgstr ""

#. TRANSLATORS: Proper name of star HD 52265
#. TRANSLATORS: Citalá means River of stars in the native Nahuat language.
#. TRANSLATORS: https://iau.org/news/pressreleases/detail/iau1912/
msgid "Citalá"
msgstr ""

