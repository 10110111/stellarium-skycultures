# Sky culture name
msgid "Modern (IAU)"
msgstr "আধুনিক (IAU)"

#. TRANSLATORS: Proper name of star 14 Andromedae
#. TRANSLATORS: https://en.wikipedia.org/wiki/14_Andromedae
msgid "Veritate"
msgstr "ভেরিতাতে"

#. TRANSLATORS: Proper name of star 18 Delphini
#. TRANSLATORS: https://en.wikipedia.org/wiki/18_Delphini
msgid "Musica"
msgstr "মুজিকা"

#. TRANSLATORS: Proper name of star 42 Draconis
#. TRANSLATORS: https://en.wikipedia.org/wiki/42_Draconis
msgid "Fafnir"
msgstr "ফাফনির"

#. TRANSLATORS: Proper name of star 47 Ursae Majoris
#. TRANSLATORS: https://en.wikipedia.org/wiki/47_Ursae_Majoris
msgid "Chalawan"
msgstr "ছালাওয়ান"

#. TRANSLATORS: Proper name of star 51 Pegasi
#. TRANSLATORS: https://en.wikipedia.org/wiki/51_Pegasi
msgid "Helvetios"
msgstr "হেলভেতিয়স"

#. TRANSLATORS: Proper name of star 55 Cancri
#. TRANSLATORS: https://en.wikipedia.org/wiki/55_Cancri
msgid "Copernicus"
msgstr "কোপার্নিকাস"

#. TRANSLATORS: Proper name of star epsilon Eridani
#. TRANSLATORS: https://en.wikipedia.org/wiki/Epsilon_Eridani
msgid "Ran"
msgstr "রাং"

#. TRANSLATORS: Proper name of star HD 104985
#. TRANSLATORS: https://en.wikipedia.org/wiki/HD_104985
msgid "Tonatiuh"
msgstr "টোনাটিহ্"

#. TRANSLATORS: Proper name of star HD 149026
#. TRANSLATORS: https://en.wikipedia.org/wiki/HD_149026
msgid "Ogma"
msgstr "ওগমা"

#. TRANSLATORS: Proper name of star HD 81688
#. TRANSLATORS: https://en.wikipedia.org/wiki/41_Lyncis
msgid "Intercrus"
msgstr "ইন্টেরক্রুশ"

#. TRANSLATORS: Proper name of star mu Arae
#. TRANSLATORS: https://en.wikipedia.org/wiki/Mu_Arae
msgid "Cervantes"
msgstr "সেরভান্তেস"

#. TRANSLATORS: Proper name of star upsilon Andromedae
#. TRANSLATORS: https://en.wikipedia.org/wiki/Upsilon_Andromedae
msgid "Titawin"
msgstr "টিটাউইন"

#. TRANSLATORS: Proper name of star xi Aquilae
#. TRANSLATORS: https://en.wikipedia.org/wiki/Xi_Aquilae
msgid "Libertas"
msgstr "লিবেরটাস"

#. TRANSLATORS: Proper name of star HD 82886
#. TRANSLATORS: Historians largely believe that the Albanians are descendants
#. of the Illyrians, a term Albanians proudly call themselves.
#. TRANSLATORS: https://iau.org/news/pressreleases/detail/iau1912/
msgid "Illyrian"
msgstr "ইলরিয়ান"

#. TRANSLATORS: Proper name of star HD 28678
#. TRANSLATORS: Hoggar is the name of the main mountain range in the Sahara
#. Desert in southern Algeria.
#. TRANSLATORS: https://iau.org/news/pressreleases/detail/iau1912/
msgid "Hoggar"
msgstr "হোগগার"

#. TRANSLATORS: Proper name of star HD 131496
#. TRANSLATORS: Arcalis is a famous peak in the north of Andorra, where the
#. Sun passes through a hole in the mountain twice a year at fixed dates. It
#. was used as a primitive solar calendar and reference point for shepherds
#. and early inhabitants of Andorra.
#. TRANSLATORS: https://iau.org/news/pressreleases/detail/iau1912/
msgid "Arcalís"
msgstr "আর্কালিস"

#. TRANSLATORS: Proper name of star HD 48265
#. TRANSLATORS: Nosaxa means spring in the Moqoit language. The word comes
#. from a combination of nosahuec, which means renew, and ñaaxa, which means
#. year.
#. TRANSLATORS: https://iau.org/news/pressreleases/detail/iau1912/
msgid "Nosaxa"
msgstr "নোসাক্সা"

#. TRANSLATORS: Proper name of star HD 38283
#. TRANSLATORS: Bubup is the Boonwurrung word for child.
#. TRANSLATORS: https://iau.org/news/pressreleases/detail/iau1912/
msgid "Bubup"
msgstr "বুবুপ"

#. TRANSLATORS: Proper name of star HD 152581
#. TRANSLATORS: Mahsati Ganjavi (1089–1159) is one of the brightest shining
#. stars of Azerbaijani poetry. She was said to have associated with both Omar
#. Khayyam and Nizami and was well educated and talented and played numerous
#. musical instruments.
#. TRANSLATORS: https://iau.org/news/pressreleases/detail/iau1912/
msgid "Mahsati"
msgstr "মহাস্তি"

#. TRANSLATORS: Proper name of star HD 148427
#. TRANSLATORS: Timir means darkness in Bengali language, alluding to the star
#. being far away in the darkness of space.
#. TRANSLATORS: https://iau.org/news/pressreleases/detail/iau1912/
msgid "Timir"
msgstr "তিমির"

#. TRANSLATORS: Proper name of star HD 49674
#. TRANSLATORS: Nervia, adapted from Nervii, was a prominent Belgian Celtic
#. tribe.
#. TRANSLATORS: https://iau.org/news/pressreleases/detail/iau1912/
msgid "Nervia"
msgstr "নার্ভি"

#. TRANSLATORS: Proper name of star HD 73534
#. TRANSLATORS: Gakyid means happiness. Gross National Happiness is the
#. development philosophy conceived and followed in Bhutan and is one of
#. Bhutan's contributions to the world.
#. TRANSLATORS: https://iau.org/news/pressreleases/detail/iau1912/
msgid "Gakyid"
msgstr "গাকাইড"

#. TRANSLATORS: Proper name of star HD 63765
#. TRANSLATORS: Tapecue means eternal path in Guarani and represents the Milky
#. Way through which the first inhabitants of the Earth arrived and could
#. return.
#. TRANSLATORS: https://iau.org/news/pressreleases/detail/iau1912/
msgid "Tapecue"
msgstr "ট্যাপিকিউ"

#. TRANSLATORS: Proper name of star HD 206610
#. TRANSLATORS: Bosona is the name given to the territory of Bosnia in the
#. 10th century. Later, the name was transformed to Bosnia originating from
#. the name of the Bosna river.
#. TRANSLATORS: https://iau.org/news/pressreleases/detail/iau1912/
msgid "Bosona"
msgstr "বোসোনা"

#. TRANSLATORS: Proper name of star HD 23079
#. TRANSLATORS: Tupi is the name of the most populous Indigenous People living
#. on the eastern coast of South America, before the Portuguese arrived in the
#. 16th century.
#. TRANSLATORS: https://iau.org/news/pressreleases/detail/iau1912/
msgid "Tupi"
msgstr "তাপী"

#. TRANSLATORS: Proper name of star HD 179949
#. TRANSLATORS: Gumala is a Malay word, which means a magic bezoar stone found
#. in snakes, dragons, etc.
#. TRANSLATORS: https://iau.org/news/pressreleases/detail/iau1912/
msgid "Gumala"
msgstr "গুমালা"

#. TRANSLATORS: Proper name of star HD 30856
#. TRANSLATORS: Mouhoun, also called Volta Noire, is the largest river in
#. Burkina Faso and plays an important role in the lives of the people in the
#. areas it passes through.
#. TRANSLATORS: https://iau.org/news/pressreleases/detail/iau1912/
msgid "Mouhoun"
msgstr "মাউহউন"

#. TRANSLATORS: Proper name of star HD 136418
#. TRANSLATORS: Nikawiy is the word for mother in the Indigenous Cree language
#. of Canada.
#. TRANSLATORS: https://iau.org/news/pressreleases/detail/iau1912/
msgid "Nikawiy"
msgstr "নিকাউইয়া"

#. TRANSLATORS: Proper name of star HD 164604
#. TRANSLATORS: Pincoya is a female water spirit from southern Chilean
#. mythology who is said to bring drowned sailors to the Caleuche so that they
#. can live in the afterlife.
#. TRANSLATORS: https://iau.org/news/pressreleases/detail/iau1912/
msgid "Pincoya"
msgstr "পিনকোয়া"

#. TRANSLATORS: Proper name of star HD 212771
#. TRANSLATORS: Lion Rock is a lion-shaped peak overlooking Hong Kong and is a
#. cultural symbol with deep respect from the local community.
#. TRANSLATORS: https://iau.org/news/pressreleases/detail/iau1912/
msgid "Lionrock"
msgstr "লায়ন রক"

#. TRANSLATORS: Proper name of star HD 173416
#. TRANSLATORS: Xihe (羲和) is the goddess of the sun in the Chinese mythology
#. and also represents the earliest astronomers and developers of calendars in
#. ancient China.
#. TRANSLATORS: https://iau.org/news/pressreleases/detail/iau1912/
msgid "Xihe"
msgstr "শিহ"

#. TRANSLATORS: Proper name of star HD 100655
#. TRANSLATORS: Formosa is the historical name of Taiwan used in the 17th
#. century, meaning beautiful in Latin.
#. TRANSLATORS: https://iau.org/news/pressreleases/detail/iau1912/
msgid "Formosa"
msgstr "ফর্মোসা"

#. TRANSLATORS: Proper name of star HD 93083
#. TRANSLATORS: Macondo is the mythical village of the novel One Hundred Years
#. of Solitude (Cien años de soledad) the classic novel by Gabriel García
#. Marquez. Macondo is a fictional place where magic and reality are mixed.
#. TRANSLATORS: https://iau.org/news/pressreleases/detail/iau1912/
msgid "Macondo"
msgstr "ম্যাকন্ডো"

#. TRANSLATORS: Proper name of star HD 221287
#. TRANSLATORS: Poerava is the word in the Cook Islands Maori language for a
#. large mystical black pearl of utter beauty and perfection.
#. TRANSLATORS: https://iau.org/news/pressreleases/detail/iau1912/
msgid "Poerava"
msgstr "পোয়ারাভা"

#. TRANSLATORS: Proper name of star HD 75898
#. TRANSLATORS: Stribor is God of winds in Slavic mythology, as well as a
#. literature character in the book Priče iz davnine (Croatian Tales of Long
#. Ago) by the Croatian author Ivana Brlić-Mažuranić.
#. TRANSLATORS: https://iau.org/news/pressreleases/detail/iau1912/
msgid "Stribor"
msgstr "স্ট্রাইবার"

#. TRANSLATORS: Proper name of star BD-17 63
#. TRANSLATORS: Felix Varela (1788–1853) was the first to teach science in
#. Cuba at the San Carlos and San Ambrosio Seminary. He opened the way to
#. education for all, and began the experimental teaching of physics in Cuba.
#. TRANSLATORS: https://iau.org/news/pressreleases/detail/iau1912/
msgid "Felixvarela"
msgstr "ফেলিক্স ভারেলা"

#. TRANSLATORS: Proper name of star HD 168746
#. TRANSLATORS: Alasia is the first historically recorded name of Cyprus,
#. dating back to mid-fifteenth century BC.
#. TRANSLATORS: https://iau.org/news/pressreleases/detail/iau1912/
msgid "Alasia"
msgstr "আলাসিয়া"

#. TRANSLATORS: Proper name of star HD 6434
#. TRANSLATORS: Nenque means the Sun in the language spoken by the Indigenous
#. Waorani tribes of the Amazon regions of Ecuador
#. TRANSLATORS: https://iau.org/news/pressreleases/detail/iau1912/
msgid "Nenque"
msgstr "নেনকে"

#. TRANSLATORS: Proper name of star HD 52265
#. TRANSLATORS: Citalá means River of stars in the native Nahuat language.
#. TRANSLATORS: https://iau.org/news/pressreleases/detail/iau1912/
msgid "Citalá"
msgstr "সিটালা"

#. TRANSLATORS: Proper name of star HD 16175
#. TRANSLATORS: Buna is the commonly used word for coffee in Ethiopia.
#. TRANSLATORS: https://iau.org/news/pressreleases/detail/iau1912/
msgid "Buna"
msgstr "বুনা"

#. TRANSLATORS: Proper name of star HD 8574
#. TRANSLATORS: Bélénos was the god of light, of the Sun, and of health in
#. Gaulish mythology.
#. TRANSLATORS: https://iau.org/news/pressreleases/detail/iau1912/
msgid "Bélénos"
msgstr "বেলানস"

#. TRANSLATORS: Proper name of star HD 208487
#. TRANSLATORS: Itonda, in the Myene tongue, corresponds to all that is
#. beautiful.
#. TRANSLATORS: https://iau.org/news/pressreleases/detail/iau1912/
msgid "Itonda"
msgstr "ইটন্ডা"

#. TRANSLATORS: Proper name of star HD 32518
#. TRANSLATORS: Mago is a National Park in Ethiopia noted for its giraffes.
#. The star also happens to be in the constellation of Camelopardis (the
#. giraffe).
#. TRANSLATORS: https://iau.org/news/pressreleases/detail/iau1912/
msgid "Mago"
msgstr "মাগো"

#. TRANSLATORS: Proper name of star HD 181720
#. TRANSLATORS: Sika means gold in the Ewe language and gold is one of Ghana's
#. principal exports.
#. TRANSLATORS: https://iau.org/news/pressreleases/detail/iau1912/
msgid "Sika"
msgstr "সিকা"

#. TRANSLATORS: Proper name of star HD 1502
#. TRANSLATORS: The Citadelle is a large mountaintop fortress in Nord, Haiti
#. built after Haiti's independence, and was designated a UNESCO World
#. Heritage site along with the nearby Sans-Souci Palace.
#. TRANSLATORS: https://iau.org/news/pressreleases/detail/iau1912/
msgid "Citadelle"
msgstr "সিটাডেল"

#. TRANSLATORS: Proper name of star HD 98219
#. TRANSLATORS: Hunahpú was one of the twin gods who became the Sun in K'iche'
#. (Quiché) Mayan mythology as recounted in the Popol Vuh.
#. TRANSLATORS: https://iau.org/news/pressreleases/detail/iau1912/
msgid "Hunahpú"
msgstr "হুনাহ্পেু"

#. TRANSLATORS: Proper name of star HAT-P-2
#. TRANSLATORS: Hunor was a legendary ancestor of the Huns and the Hungarian
#. nation, and brother of Magor.
#. TRANSLATORS: https://iau.org/news/pressreleases/detail/iau1912/
msgid "Hunor"
msgstr "হুনার"

#. TRANSLATORS: Proper name of star HD 109246
#. TRANSLATORS: Funi is an old Icelandic word meaning fire or blaze.
#. TRANSLATORS: https://iau.org/news/pressreleases/detail/iau1912/
msgid "Funi"
msgstr "ফুনি"

#. TRANSLATORS: Proper name of star HD 86081
#. TRANSLATORS: Bibhā [/bɪbɦa/] is the Bengali pronunciation of the Sanskrit
#. word Vibha, which means a bright beam of light.
#. TRANSLATORS: https://iau.org/news/pressreleases/detail/iau1912/
msgid "Bibhā"
msgstr "বিভা"

#. TRANSLATORS: Proper name of star HD 117618
#. TRANSLATORS: Dofida means our star in Nias language.
#. TRANSLATORS: https://iau.org/news/pressreleases/detail/iau1912/
msgid "Dofida"
msgstr "দোফিডা"

#. TRANSLATORS: Proper name of star HD 175541
#. TRANSLATORS: Kaveh is one of the heroes of Shahnameh, the epic poem
#. composed by Persian poet Ferdowsi between 977 and 1010 CE. Kaveh is a
#. blacksmith who symbolises justice.
#. TRANSLATORS: https://iau.org/news/pressreleases/detail/iau1912/
msgid "Kaveh"
msgstr "কাভা"

#. TRANSLATORS: Proper name of star HD 231701
#. TRANSLATORS: Uruk was an ancient city of the Sumer and Babylonian
#. civilizations in Mesopotamia situated along an ancient channel of the
#. Euphrates river in modern-day Iraq.
#. TRANSLATORS: https://iau.org/news/pressreleases/detail/iau1912/
msgid "Uruk"
msgstr "উরুক"

#. TRANSLATORS: Proper name of star HD 102195
#. TRANSLATORS: Flegetonte is the underworld river of fire from Greek
#. Mythology in the Italian narrative poem on the afterlife 'Divina Commedia'
#. (Divine Commedy) by Dante Alighieri, chosen as an allusion to the star's
#. fiery nature.
#. TRANSLATORS: https://iau.org/news/pressreleases/detail/iau1912/
msgid "Flegetonte"
msgstr "ফ্লেজেটন্টে"

#. TRANSLATORS: Proper name of star HD 83443
#. TRANSLATORS: The word Kalausi means a very strong whirling column of wind
#. in the Dholuo language of Kenya.
#. TRANSLATORS: https://iau.org/news/pressreleases/detail/iau1912/
msgid "Kalausi"
msgstr "কালাউসি"

#. TRANSLATORS: Proper name of star HD 118203
#. TRANSLATORS: Liesma means flame, and it is the name of a character from the
#. Latvian poem Staburags un Liesma.
#. TRANSLATORS: https://iau.org/news/pressreleases/detail/iau1912/
msgid "Liesma"
msgstr "লাইসমা"

#. TRANSLATORS: Proper name of star HD 192263
#. TRANSLATORS: Phoenicia was an ancient thalassocratic civilisation of the
#. Mediterranean that originated from the area of modern-day Lebanon.
#. TRANSLATORS: https://iau.org/news/pressreleases/detail/iau1912/
msgid "Phoenicia"
msgstr "ফেনিসিয়া"

#. TRANSLATORS: Proper name of star HD 45350
#. TRANSLATORS: The Lucilinburhuc fortress was built in 963 by the founder of
#. Luxembourg, Count Siegfried.
#. TRANSLATORS: https://iau.org/news/pressreleases/detail/iau1912/
msgid "Lucilinburhuc"
msgstr "লুসিলিনবুরহুক"

#. TRANSLATORS: Proper name of star HD 153950
#. TRANSLATORS: Rapeto is a giant creature from Malagasy tales.
#. TRANSLATORS: https://iau.org/news/pressreleases/detail/iau1912/
msgid "Rapeto"
msgstr "রাপেটো"

#. TRANSLATORS: Proper name of star HD 20868
#. TRANSLATORS: Intan means diamond in the Malay language (Bahasa Melayu),
#. alluding to the shining of a star.
#. TRANSLATORS: https://iau.org/news/pressreleases/detail/iau1912/
msgid "Intan"
msgstr "ইন্টান"

#. TRANSLATORS: Proper name of star HD 224693
#. TRANSLATORS: Axólotl means water animal in the native Nahuatl language,
#. which is a unique and culturally significant endemic amphibious species
#. from the basin of Mexico.
#. TRANSLATORS: https://iau.org/news/pressreleases/detail/iau1912/
msgid "Axólotl"
msgstr "অ্যাশোলোল"

#. TRANSLATORS: Proper name of star HD 7199
#. TRANSLATORS: Emiw represents love in the local Makhuwa language of the
#. northern region of Mozambique.
#. TRANSLATORS: https://iau.org/news/pressreleases/detail/iau1912/
msgid "Emiw"
msgstr "এমইউ"

#. TRANSLATORS: Proper name of star HD 18742
#. TRANSLATORS: Ayeyarwady is the largest and most important river in Myanmar.
#. TRANSLATORS: https://iau.org/news/pressreleases/detail/iau1912/
msgid "Ayeyarwady"
msgstr "আইয়ারওয়াদী"

#. TRANSLATORS: Proper name of star HD 100777
#. TRANSLATORS: Sagarmatha is the Nepali name for the highest peak in the
#. world (also known as Mount Everest) and symbol of national pride of Nepal.
#. TRANSLATORS: https://iau.org/news/pressreleases/detail/iau1912/
msgid "Sagarmatha"
msgstr "সগরমাথা"

#. TRANSLATORS: Proper name of star HD 137388
#. TRANSLATORS: Karaka is the word in the Māori language for a plant endemic
#. to New Zealand that produces a bright orange, fleshy fruit.
#. TRANSLATORS: https://iau.org/news/pressreleases/detail/iau1912/
msgid "Karaka"
msgstr "কারাকা"

#. TRANSLATORS: Proper name of star HD 4208
#. TRANSLATORS: Cocibolca is the Nahualt name for the largest lake in Central
#. America in Nicaragua.
#. TRANSLATORS: https://iau.org/news/pressreleases/detail/iau1912/
msgid "Cocibolca"
msgstr "কোকিবলকা"

#. TRANSLATORS: Proper name of star HD 43197
#. TRANSLATORS: Amadioha is the god of thunder in Igbo mythology. As well as
#. representing justice, Amadioha is also a god of love, peace and unity.
#. TRANSLATORS: https://iau.org/news/pressreleases/detail/iau1912/
msgid "Amadioha"
msgstr "আমাদিওহা"

#. TRANSLATORS: Proper name of star HD 68988
#. TRANSLATORS: Násti means star in the Northern Sami language of Norway.
#. TRANSLATORS: https://iau.org/news/pressreleases/detail/iau1912/
msgid "Násti"
msgstr "নাস্টি"

#. TRANSLATORS: Proper name of star HAT-P-23
#. TRANSLATORS: Shama is an Urdu literary term meaning a small lamp or flame,
#. symbolic of the light of the star.
#. TRANSLATORS: https://iau.org/news/pressreleases/detail/iau1912/
msgid "Shama"
msgstr "শামা"

#. TRANSLATORS: Proper name of star HD 108147
#. TRANSLATORS: Tupã is one of four principle gods of the Guarani Cosmogony in
#. popular Paraguayan folklore that helped the supreme god Ñamandu to create
#. the Universe.
#. TRANSLATORS: https://iau.org/news/pressreleases/detail/iau1912/
msgid "Tupã"
msgstr "টুপা"

#. TRANSLATORS: Proper name of star HD 156411
#. TRANSLATORS: Inquil was one half of the couple involved in the tragic love
#. story Way to the Sun by famous Peruvian writer Abraham Valdelomar.
#. TRANSLATORS: https://iau.org/news/pressreleases/detail/iau1912/
msgid "Inquill"
msgstr "ইনকুইল"

#. TRANSLATORS: Proper name of star HD 102117
#. TRANSLATORS: Uklun means us or we in the Pitkern language of the people of
#. Pitcairn Islands.
#. TRANSLATORS: https://iau.org/news/pressreleases/detail/iau1912/
msgid "Uklun"
msgstr "উকলুন"

#. TRANSLATORS: Proper name of star BD+14 4559
#. TRANSLATORS: Solaris is the title of a 1961 science fiction novel about an
#. ocean-covered exoplanet by Polish writer Stanislaw Lem.
#. TRANSLATORS: https://iau.org/news/pressreleases/detail/iau1912/
msgid "Solaris"
msgstr "সোলারিস"

#. TRANSLATORS: Proper name of star HD 45652
#. TRANSLATORS: Lusitânia is the ancient name of the western region of the
#. Iberic Peninsula where the Lusitanian people lived and where most of
#. modern-day Portugal is situated.
#. TRANSLATORS: https://iau.org/news/pressreleases/detail/iau1912/
msgid "Lusitânia"
msgstr "লুসিটানিয়া"

#. TRANSLATORS: Proper name of star HIP 12961
#. TRANSLATORS: Koeia was the word for star in the language of the Taíno
#. Indigenous People of the Caribbean.
#. TRANSLATORS: https://iau.org/news/pressreleases/detail/iau1912/
msgid "Koeia"
msgstr "কোইয়া"

#. TRANSLATORS: Proper name of star HD 181342
#. TRANSLATORS: Belel is a rare source of water in the north of Senegal.
#. TRANSLATORS: https://iau.org/news/pressreleases/detail/iau1912/
msgid "Belel"
msgstr "বেলেল"

#. TRANSLATORS: Proper name of star 8 Umi
#. TRANSLATORS: Baekdu is the highest mountain on the Korean peninsula,
#. situated in North Korea, and symbolises the national spirit of Korea.
#. TRANSLATORS: https://iau.org/news/pressreleases/detail/iau1912/
msgid "Baekdu"
msgstr "বায়েকডু"

#. TRANSLATORS: Proper name of star HD 149143
#. TRANSLATORS: Rosalía de Castro was a significant figure of Galician culture
#. and prominent Spanish writer, whose pioneeting work often referenced the
#. night and celestial objects.
#. TRANSLATORS: https://iau.org/news/pressreleases/detail/iau1912/
msgid "Rosalíadecastro"
msgstr "রোজালিয়া দে কাস্ত্রো"

#. TRANSLATORS: Proper name of star HD 205739
#. TRANSLATORS: Sāmaya means peace in the Sinhalese language.
#. TRANSLATORS: https://iau.org/news/pressreleases/detail/iau1912/
msgid "Sāmaya"
msgstr "সাম্য"

#. TRANSLATORS: Proper name of star HD 102956
